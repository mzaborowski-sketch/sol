    .floating-start {
      position: fixed;
      top: 18px;
      right: 18px;
      z-index: 1000;
    }

    .floating-start a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 98px;
      min-height: 48px;
      padding: 8px 14px;
      border-radius: 999px;
      background: #0f172a;
      color: #ffffff;
      border: 3px solid #ffffff;
      outline: 3px solid #ffd21f;
      box-shadow: 0 18px 40px rgba(15, 23, 42, 0.42), 0 0 0 7px rgba(255, 210, 31, 0.18);
      text-decoration: none;
      font-weight: 900;
      letter-spacing: 0;
      -webkit-tap-highlight-color: transparent;
      transition: transform 140ms ease, filter 140ms ease, box-shadow 140ms ease;
    }

    .floating-start a:hover,
    .floating-start a:focus {
      color: #ffffff;
      text-decoration: none;
      filter: brightness(1.05);
    }

    .floating-start a:active,
    .floating-start a.menu-pop {
      transform: translateY(-2px) scale(1.06);
      filter: brightness(1.08);
      box-shadow: 0 22px 46px rgba(15, 23, 42, 0.46), 0 0 0 7px rgba(255, 210, 31, 0.22);
      animation: menuTapShake 180ms ease-out both;
    }

    @keyframes menuTapShake {
      0% { transform: translateY(0) scale(1); }
      25% { transform: translateY(-2px) translateX(-2px) scale(1.06); }
      50% { transform: translateY(-2px) translateX(2px) scale(1.06); }
      75% { transform: translateY(-2px) translateX(-1px) scale(1.06); }
      100% { transform: translateY(-2px) translateX(0) scale(1.06); }
    }

    @media (max-width: 640px) {
      .floating-start {
        top: 9px;
        right: 9px;
      }

      .floating-start a {
