  (function () {
    var audioCtx = null;
    var lastPulseAt = 0;

    function clickSound() {
      try {
        var AudioContext = window.AudioContext || window.webkitAudioContext;
        if (!AudioContext) return;
        audioCtx = audioCtx || new AudioContext();
        if (audioCtx.state === 'suspended') audioCtx.resume();

        var osc = audioCtx.createOscillator();
        var gain = audioCtx.createGain();
        osc.type = 'sine';
        osc.frequency.setValueAtTime(760, audioCtx.currentTime);
        osc.frequency.exponentialRampToValueAtTime(520, audioCtx.currentTime + 0.055);
        gain.gain.setValueAtTime(0.0001, audioCtx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.055, audioCtx.currentTime + 0.006);
        gain.gain.exponentialRampToValueAtTime(0.0001, audioCtx.currentTime + 0.075);
        osc.connect(gain);
        gain.connect(audioCtx.destination);
        osc.start();
        osc.stop(audioCtx.currentTime + 0.08);
      } catch (err) {
        // Dźwięk jest dodatkiem; na części telefonów przeglądarka może go zablokować.
      }
    }

    function pulse(tile) {
      if (!tile) return;
      var now = Date.now();
      if (now - lastPulseAt < 80) return;
      lastPulseAt = now;
      tile.classList.remove('tile-pop');
      void tile.offsetWidth;
      tile.classList.add('tile-pop');
      window.setTimeout(function () {
        tile.classList.remove('tile-pop');
      }, 220);
      if (navigator.vibrate) navigator.vibrate([28, 18, 28]);
      clickSound();
    }

    document.querySelectorAll('.tile').forEach(function (tile) {
      tile.addEventListener('pointerdown', function () {
        pulse(tile);
      }, { passive: true });
      tile.addEventListener('touchstart', function () {
        pulse(tile);
      }, { passive: true });
      tile.addEventListener('mousedown', function () {
        pulse(tile);
      }, { passive: true });
      tile.addEventListener('click', function (event) {
        if (event.defaultPrevented || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey || event.button) return;
        var href = tile.getAttribute('href');
        if (!href || tile.getAttribute('target') === '_blank') return;
        event.preventDefault();
        pulse(tile);
        window.setTimeout(function () {
          window.location.href = href;
        }, 180);
      });
    });

    document.querySelectorAll('.floating-start a').forEach(function (link) {
      link.addEventListener('pointerdown', function () {
        link.classList.remove('menu-pop');
        void link.offsetWidth;
        link.classList.add('menu-pop');
        window.setTimeout(function () {
          link.classList.remove('menu-pop');
        }, 220);
        if (navigator.vibrate) navigator.vibrate([28, 18, 28]);
        clickSound();
      }, { passive: true });
    });
  })();
